{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "packages/core/src/**/*",
    "packages/core/src/**/*.vue",
    "apps/*/src/**/*",
    "apps/*/src/**/*.vue"
  ],
  "exclude": ["packages/core/src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noUnusedLocals": false,

    "paths": {
      "@/*": ["./packages/core/src/*"]
    }
  }
}
